{
  "name": "@monzingo89/engineer-maxxing",
  "version": "1.0.9",
  "description": "Code-agnostic observable repo memory system.",
  "type": "module",
  "bin": {
    "engineer-maxxing": "dist/cortex/cli/learn.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Monzingo89/engineer-maxxing.git"
  },
  "homepage": "https://github.com/Monzingo89/engineer-maxxing#readme",
  "bugs": {
    "url": "https://github.com/Monzingo89/engineer-maxxing/issues"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsx cortex/cli/learn.ts",
    "workflow:learn": "tsx cortex/cli/learn.ts",
    "workflow:clean": "tsx cortex/cli/learn.ts clean-repo",
    "workflow:reorganize": "tsx cortex/cli/learn.ts reorganize-repo",
    "workflow:execute": "tsx cortex/cli/learn.ts execute-repo",
    "workflow:setup": "tsx cortex/cli/learn.ts setup-repo --fresh",
    "start": "node dist/cortex/cli/learn.js",
    "lint": "tsc --noEmit",
    "test:dist": "node --test dist/cortex/tests/*.test.js",
    "test": "npm run build && npm run test:dist",
    "verify:publish": "npm run lint && npm run build && npm run test:dist && npm pack --dry-run",
    "release:patch": "npm version patch && npm run verify:publish",
    "release:minor": "npm version minor && npm run verify:publish",
    "release:patch:local": "npm version patch --no-git-tag-version && npm run verify:publish",
    "release:minor:local": "npm version minor --no-git-tag-version && npm run verify:publish",
    "publish:npmjs": "npm publish --access public --registry=https://registry.npmjs.org \"--@monzingo89:registry=https://registry.npmjs.org\"",
    "publish:github": "npm publish --registry=https://npm.pkg.github.com \"--@monzingo89:registry=https://npm.pkg.github.com\"",
    "publish:dual": "npm run publish:npmjs && npm run publish:github",
    "publish:public": "npm run publish:npmjs",
    "release:patch:dual": "npm version patch && npm run verify:publish && npm run publish:dual",
    "release:minor:dual": "npm version minor && npm run verify:publish && npm run publish:dual",
    "prepublishOnly": "npm run verify:publish"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT"
}
